datasource db {
  provider = "postgresql"
}


generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

// --- Enum Definitions ---

enum AccountStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum AppointmentStatus {
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  UNPAID
  CANCELLED
}

enum DomainStatus {
  PENDING
  VERIFIED
  SSL_PROVISIONING
  ACTIVE
  FAILED
}

enum WebhookStatus {
  PENDING
  PROCESSED
  FAILED
}

enum RefundStatus {
  PENDING
  PROCESSED
  FAILED
}

enum InvoiceStatus {
  PAID
  UNPAID
  VOID
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  READ
}

enum NotificationChannel {
  WHATSAPP
  SMS
  EMAIL
  IN_APP
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  FAILED
}

enum CampaignChannel {
  WHATSAPP
  SMS
}

enum ConsentType {
  MARKETING_WHATSAPP
  MARKETING_SMS
  DATA_PROCESSING
}

enum ConsentSource {
  BOOKING_FORM
  MANUAL
  IMPORT
}

enum IncidentSeverity {
  P1
  P2
  P3
  P4
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  RESOLVED
}

enum DeletionRequestStatus {
  PENDING
  PROCESSED
  CANCELLED
}

enum SystemStatusType {
  OPERATIONAL
  DEGRADED
  PARTIAL_OUTAGE
  MAJOR_OUTAGE
  MAINTENANCE
}

// --- Auth & Users ---

model User {
  id            String          @id @default(uuid()) @db.Uuid
  name          String?
  email         String          @unique
  phone         String?         @unique
  passwordHash  String
  oauthProvider String?
  oauthId       String?
  mfaSecret     String?
  lastLogin     DateTime?
  status        AccountStatus   @default(ACTIVE)
  createdAt     DateTime        @default(now()) @db.Timestamptz
  updatedAt     DateTime        @updatedAt @db.Timestamptz
  deletedAt     DateTime?       @db.Timestamptz

  membership    BusinessMember?

  @@map("users")
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  name        String
  description String?
  businessId  String?          @db.Uuid
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now()) @db.Timestamptz
  updatedAt   DateTime         @updatedAt @db.Timestamptz
  deletedAt   DateTime?        @db.Timestamptz

  business    Business?        @relation(fields: [businessId], references: [id])
  permissions RolePermission[]
  members     BusinessMember[]
  staff       Staff[]

  @@index([businessId])
  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  name        String           @unique // e.g. "appointment:create"
  description String?
  createdAt   DateTime         @default(now()) @db.Timestamptz
  updatedAt   DateTime         @updatedAt @db.Timestamptz

  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// --- Tenant Core ---

model Business {
  id                 String             @id @default(uuid()) @db.Uuid
  name               String
  slug               String             @unique
  phone              String?
  email              String?
  description        String?            @db.Text
  logoUrl            String?
  status             AccountStatus      @default(ACTIVE)
  planId             String?            @db.Uuid
  subscriptionStatus SubscriptionStatus @default(TRIALING)
  trialEndsAt        DateTime           @db.Timestamptz
  version            Int                @default(1)
  createdBy          String?            @db.Uuid
  updatedBy          String?            @db.Uuid
  createdAt          DateTime           @default(now()) @db.Timestamptz
  updatedAt          DateTime           @updatedAt @db.Timestamptz
  deletedAt          DateTime?          @db.Timestamptz

  branches           Branch[]
  members            BusinessMember[]
  roles              Role[]
  services           Service[]
  serviceCategories  ServiceCategory[]
  staff              Staff[]
  customers          Customer[]
  appointments       Appointment[]
  payments           Payment[]
  refunds            Refund[]
  invoices           Invoice[]
  subscriptions      Subscription[]
  websites           Website[]
  themes             Theme[]
  auditLogs          AuditLog[]
  notifications      Notification[]
  leaves             Leave[]
  reviews            Review[]
  campaigns          Campaign[]
  memberships        Membership[]
  packages           Package[]
  inventories        Inventory[]
  consents           Consent[]
  mediaAssets        MediaAsset[]
  paymentConfigs     PaymentConfig[]
  dataDeletionRequests DataDeletionRequest[]

  @@map("businesses")
}

model Branch {
  id           String        @id @default(uuid()) @db.Uuid
  businessId   String        @db.Uuid
  name         String
  address      String
  phone        String
  email        String?
  timezone     String        @default("Asia/Kolkata")
  workingHours Json
  version      Int           @default(1)
  createdBy    String?       @db.Uuid
  updatedBy    String?       @db.Uuid
  createdAt    DateTime      @default(now()) @db.Timestamptz
  updatedAt    DateTime      @updatedAt @db.Timestamptz
  deletedAt    DateTime?     @db.Timestamptz

  business     Business      @relation(fields: [businessId], references: [id])
  staff        Staff[]
  appointments Appointment[]

  @@index([businessId])
  @@map("branches")
}

model BusinessMember {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  businessId String    @db.Uuid
  roleId    String    @db.Uuid
  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt @db.Timestamptz
  deletedAt DateTime? @db.Timestamptz

  user      User      @relation(fields: [userId], references: [id])
  business  Business  @relation(fields: [businessId], references: [id])
  role      Role      @relation(fields: [roleId], references: [id])
  staff     Staff[]

  @@unique([userId])
  @@index([businessId])
  @@index([userId])
  @@map("business_members")
}

model Staff {
  id           String         @id @default(uuid()) @db.Uuid
  businessId   String         @db.Uuid
  branchId     String         @db.Uuid
  memberId     String?        @db.Uuid // Nullable if the staff does not log in
  roleId       String         @default("00000000-0000-0000-0000-000000000004") @db.Uuid
  name         String
  phone        String
  email        String
  skills       String[]
  salary       Decimal?       @db.Decimal(12, 2)
  commission   Decimal?       @db.Decimal(5, 2)
  workingHours Json
  isActive     Boolean        @default(true)
  version      Int            @default(1)
  createdBy    String?        @db.Uuid
  updatedBy    String?        @db.Uuid
  createdAt    DateTime       @default(now()) @db.Timestamptz
  updatedAt    DateTime       @updatedAt @db.Timestamptz
  deletedAt    DateTime?      @db.Timestamptz

  business     Business       @relation(fields: [businessId], references: [id])
  branch       Branch         @relation(fields: [branchId], references: [id])
  member       BusinessMember? @relation(fields: [memberId], references: [id])
  role         Role           @relation(fields: [roleId], references: [id])
  services     StaffService[]
  appointments Appointment[]
  leaves       Leave[]

  @@index([businessId])
  @@index([businessId, branchId])
  @@map("staff")
}

// --- Service Catalog ---

model ServiceCategory {
  id               String            @id @default(uuid()) @db.Uuid
  businessId       String            @db.Uuid
  name             String
  parentCategoryId String?           @db.Uuid
  isActive         Boolean           @default(true)
  createdBy        String?           @db.Uuid
  updatedBy        String?           @db.Uuid
  createdAt        DateTime          @default(now()) @db.Timestamptz
  updatedAt        DateTime          @updatedAt @db.Timestamptz
  deletedAt        DateTime?         @db.Timestamptz

  business         Business          @relation(fields: [businessId], references: [id])
  parentCategory   ServiceCategory?  @relation("SubCategories", fields: [parentCategoryId], references: [id])
  subCategories    ServiceCategory[] @relation("SubCategories")
  services         Service[]

  @@index([businessId])
  @@map("service_categories")
}

model Service {
  id          String         @id @default(uuid()) @db.Uuid
  businessId  String         @db.Uuid
  categoryId  String         @db.Uuid
  name        String
  description String?        @db.Text
  duration    Int // in minutes
  price       Decimal        @db.Decimal(10, 2)
  bufferTime  Int            @default(0) // in minutes
  isActive    Boolean        @default(true)
  version     Int            @default(1)
  createdBy   String?        @db.Uuid
  updatedBy   String?        @db.Uuid
  createdAt   DateTime       @default(now()) @db.Timestamptz
  updatedAt   DateTime       @updatedAt @db.Timestamptz
  deletedAt   DateTime?      @db.Timestamptz

  business    Business       @relation(fields: [businessId], references: [id])
  category    ServiceCategory @relation(fields: [categoryId], references: [id])
  staff       StaffService[]
  appointments Appointment[]

  @@index([businessId])
  @@map("services")
}

model StaffService {
  staffId   String @db.Uuid
  serviceId String @db.Uuid

  staff     Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([staffId, serviceId])
  @@map("staff_services")
}

// --- CRM & Appointments ---

model Customer {
  id         String        @id @default(uuid()) @db.Uuid
  businessId String        @db.Uuid
  name       String
  phone      String
  email      String?
  gender     String?
  birthday   DateTime?     @db.Date
  notes      String?       @db.Text
  totalSpent Decimal       @default(0.00) @db.Decimal(12, 2)
  version    Int           @default(1)
  createdBy  String?       @db.Uuid
  updatedBy  String?       @db.Uuid
  createdAt  DateTime      @default(now()) @db.Timestamptz
  updatedAt  DateTime      @updatedAt @db.Timestamptz
  deletedAt  DateTime?     @db.Timestamptz

  business   Business      @relation(fields: [businessId], references: [id])
  appointments Appointment[]
  reviews    Review[]
  consents   Consent[]
  notifications Notification[]
  dataDeletionRequests DataDeletionRequest[]

  @@index([businessId])
  @@index([businessId, phone])
  @@map("customers")
}

model Appointment {
  id          String            @id @default(uuid()) @db.Uuid
  businessId  String            @db.Uuid
  branchId    String            @db.Uuid
  staffId     String            @db.Uuid
  customerId  String            @db.Uuid
  serviceId   String            @db.Uuid
  status      AppointmentStatus @default(CONFIRMED)
  startTime   DateTime          @db.Timestamptz
  endTime     DateTime          @db.Timestamptz
  notes       String?           @db.Text
  version     Int               @default(1)
  createdBy   String?           @db.Uuid
  updatedBy   String?           @db.Uuid
  createdAt   DateTime          @default(now()) @db.Timestamptz
  updatedAt   DateTime          @updatedAt @db.Timestamptz
  deletedAt   DateTime?         @db.Timestamptz

  business    Business          @relation(fields: [businessId], references: [id])
  branch      Branch            @relation(fields: [branchId], references: [id])
  staff       Staff             @relation(fields: [staffId], references: [id])
  customer    Customer          @relation(fields: [customerId], references: [id])
  service     Service           @relation(fields: [serviceId], references: [id])
  payments    Payment[]
  invoices    Invoice[]

  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, startTime])
  @@index([staffId, startTime, endTime])
  @@index([branchId, startTime, endTime])
  @@index([customerId])
  @@index([serviceId])
  @@map("appointments")
}

// --- Payments & Subscriptions (Immutable — no soft deletes) ---

model Payment {
  id                String        @id @default(uuid()) @db.Uuid
  businessId        String        @db.Uuid
  appointmentId     String        @db.Uuid
  amount            Decimal       @db.Decimal(12, 2)
  status            PaymentStatus @default(PENDING)
  provider          String        @default("razorpay") // e.g. "razorpay"
  providerPaymentId String?       @unique
  providerOrderId   String?
  refundStatus      String?       // e.g. "full", "partial", null
  createdAt         DateTime      @default(now()) @db.Timestamptz
  updatedAt         DateTime      @updatedAt @db.Timestamptz

  business          Business      @relation(fields: [businessId], references: [id])
  appointment       Appointment   @relation(fields: [appointmentId], references: [id])
  refunds           Refund[]

  @@index([businessId])
  @@index([businessId, status])
  @@index([appointmentId])
  @@map("payments")
}

model Refund {
  id               String      @id @default(uuid()) @db.Uuid
  businessId       String      @db.Uuid
  paymentId        String      @db.Uuid
  amount           Decimal     @db.Decimal(12, 2)
  status           RefundStatus @default(PENDING)
  providerRefundId String?     @unique
  createdAt        DateTime    @default(now()) @db.Timestamptz
  updatedAt        DateTime    @updatedAt @db.Timestamptz

  business         Business    @relation(fields: [businessId], references: [id])
  payment          Payment     @relation(fields: [paymentId], references: [id])

  @@index([businessId])
  @@index([paymentId])
  @@map("refunds")
}

model Invoice {
  id            String      @id @default(uuid()) @db.Uuid
  businessId    String      @db.Uuid
  appointmentId String      @db.Uuid
  invoiceNumber String      @unique
  amount        Decimal     @db.Decimal(12, 2)
  status        InvoiceStatus // PAID, UNPAID, VOID
  pdfUrl        String?
  createdAt     DateTime    @default(now()) @db.Timestamptz
  updatedAt     DateTime    @updatedAt @db.Timestamptz

  business      Business    @relation(fields: [businessId], references: [id])
  appointment   Appointment @relation(fields: [appointmentId], references: [id])

  @@index([businessId])
  @@index([appointmentId])
  @@map("invoices")
}

model PaymentConfig {
  id          String   @id @default(uuid()) @db.Uuid
  businessId  String   @db.Uuid
  provider    String
  config      Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  business    Business @relation(fields: [businessId], references: [id])

  @@unique([businessId, provider])
  @@map("payment_configs")
}

model Subscription {
  id                     String             @id @default(uuid()) @db.Uuid
  businessId             String             @db.Uuid
  planId                 String             @db.Uuid
  status                 SubscriptionStatus @default(TRIALING)
  billingInterval        String             @default("monthly")
  amount                 Decimal            @default(0.00) @db.Decimal(10, 2)
  currentPeriodStart     DateTime           @db.Timestamptz
  currentPeriodEnd       DateTime           @db.Timestamptz
  razorpaySubscriptionId String?            @unique
  cancelAtPeriodEnd      Boolean            @default(false)
  createdAt              DateTime           @default(now()) @db.Timestamptz
  updatedAt              DateTime           @updatedAt @db.Timestamptz

  business               Business           @relation(fields: [businessId], references: [id])
  plan                   SubscriptionPlan   @relation(fields: [planId], references: [id])

  @@index([businessId])
  @@map("subscriptions")
}

model SubscriptionPlan {
  id              String         @id @default(uuid()) @db.Uuid
  name            String
  slug            String         @unique
  maxBranches     Int
  maxStaff        Int
  maxAppointments Int
  priceMonthly    Decimal        @db.Decimal(10, 2)
  priceYearly     Decimal        @db.Decimal(10, 2)
  features        Json
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now()) @db.Timestamptz
  updatedAt       DateTime       @updatedAt @db.Timestamptz
  deletedAt       DateTime?      @db.Timestamptz

  subscriptions   Subscription[]

  @@map("subscription_plans")
}

// --- Website Builder ---

model Website {
  id               String           @id @default(uuid()) @db.Uuid
  businessId       String           @db.Uuid
  themeId          String           @db.Uuid
  subdomain        String           @unique
  customDomain     String?          @unique
  domainStatus     DomainStatus     @default(PENDING)
  isPublished      Boolean          @default(false)
  publishedVersion Int              @default(0)
  version          Int              @default(1)
  logoUrl          String?
  faviconUrl       String?
  logoAltText      String?
  socialLinksJson  Json?            // { instagram?, facebook?, twitter?, youtube?, tiktok?, linkedin?, whatsapp? }
  createdBy        String?          @db.Uuid
  updatedBy        String?          @db.Uuid
  createdAt        DateTime         @default(now()) @db.Timestamptz
  updatedAt        DateTime         @updatedAt @db.Timestamptz
  deletedAt        DateTime?        @db.Timestamptz

  business         Business         @relation(fields: [businessId], references: [id])
  theme            Theme            @relation(fields: [themeId], references: [id])
  pages            Page[]
  domains          Domain[]
  mediaAssets      MediaAsset[]
  versions         WebsiteVersion[]

  @@index([businessId])
  @@map("websites")
}

model Page {
  id             String    @id @default(uuid()) @db.Uuid
  websiteId      String    @db.Uuid
  title          String
  slug           String
  type           String   
  contentJson    Json
  isPublished    Boolean   @default(false)
  sortOrder      Int       @default(0)
  seoTitle       String?
  seoDescription String?
  seoOgImage     String?
  createdAt      DateTime  @default(now()) @db.Timestamptz
  updatedAt      DateTime  @updatedAt @db.Timestamptz
  deletedAt      DateTime? @db.Timestamptz

  website        Website   @relation(fields: [websiteId], references: [id])

  @@unique([websiteId, slug])
  @@map("pages")
}

model Theme {
  id               String    @id @default(uuid()) @db.Uuid
  name             String
  colorsJson       Json
  typographyJson   Json
  spacingJson      Json
  buttonStylesJson Json
  layoutRulesJson  Json
  isSystem         Boolean   @default(false)
  businessId       String?   @db.Uuid
  createdAt        DateTime  @default(now()) @db.Timestamptz
  updatedAt        DateTime  @updatedAt @db.Timestamptz
  deletedAt        DateTime? @db.Timestamptz

  business         Business? @relation(fields: [businessId], references: [id])
  websites         Website[]

  @@index([businessId])
  @@map("themes")
}

model Domain {
  id          String       @id @default(uuid()) @db.Uuid
  websiteId   String       @db.Uuid
  hostname    String       @unique
  status      DomainStatus @default(PENDING)
  sslStatus   String       @default("pending") // e.g. "pending", "issued", "expired"
  dnsVerified Boolean      @default(false)
  sslIssuedAt DateTime?    @db.Timestamptz
  version     Int          @default(1)
  createdBy   String?      @db.Uuid
  updatedBy   String?      @db.Uuid
  createdAt   DateTime     @default(now()) @db.Timestamptz
  updatedAt   DateTime     @updatedAt @db.Timestamptz
  deletedAt   DateTime?    @db.Timestamptz

  website     Website      @relation(fields: [websiteId], references: [id])

  @@index([websiteId])
  @@map("domains")
}

model WebsiteVersion {
  id          String   @id @default(uuid()) @db.Uuid
  websiteId   String   @db.Uuid
  version     Int
  pagesJson   Json
  themeId     String   @db.Uuid
  createdAt   DateTime @default(now()) @db.Timestamptz

  website     Website  @relation(fields: [websiteId], references: [id])

  @@index([websiteId])
  @@map("website_versions")
}

// --- Platform Utilities (Immutable — no soft deletes) ---

model WebhookEvent {
  id              String        @id @default(uuid()) @db.Uuid
  provider        String        // e.g. "razorpay", "whatsapp", "msg91"
  eventType       String
  providerEventId String        @unique
  payload         Json
  status          WebhookStatus @default(PENDING)
  processedAt     DateTime?     @db.Timestamptz
  createdAt       DateTime      @default(now()) @db.Timestamptz
  updatedAt       DateTime      @updatedAt @db.Timestamptz

  @@map("webhook_events")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @db.Uuid
  userId     String   @db.Uuid
  action     String   // e.g. "CREATE", "UPDATE", "DELETE"
  entity     String   // e.g. "Appointment", "Payment"
  entityId   String   @db.Uuid
  metadata   Json?
  createdAt  DateTime @default(now()) @db.Timestamptz

  business   Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
  @@index([businessId, createdAt])
  @@map("audit_logs")
}

model Notification {
  id          String              @id @default(uuid()) @db.Uuid
  businessId  String              @db.Uuid
  customerId  String              @db.Uuid
  campaignId  String?             @db.Uuid
  channel     NotificationChannel // WHATSAPP, SMS, EMAIL, IN_APP
  templateId  String?
  status      NotificationStatus  @default(PENDING)
  provider    String              // "meta", "msg91", "resend", "ses"
  sentAt      DateTime?           @db.Timestamptz
  deliveredAt DateTime?           @db.Timestamptz
  failedAt    DateTime?           @db.Timestamptz
  createdAt   DateTime            @default(now()) @db.Timestamptz
  updatedAt   DateTime            @updatedAt @db.Timestamptz

  business    Business  @relation(fields: [businessId], references: [id])
  customer    Customer  @relation(fields: [customerId], references: [id])
  campaign    Campaign? @relation(fields: [campaignId], references: [id])

  @@index([businessId])
  @@index([customerId])
  @@index([campaignId])
  @@map("notifications")
}

// --- Operational Models ---

model Leave {
  id         String    @id @default(uuid()) @db.Uuid
  businessId String    @db.Uuid
  staffId    String    @db.Uuid
  startTime  DateTime  @db.Timestamptz
  endTime    DateTime  @db.Timestamptz
  reason     String?
  version    Int       @default(1)
  createdBy  String?   @db.Uuid
  updatedBy  String?   @db.Uuid
  createdAt  DateTime  @default(now()) @db.Timestamptz
  updatedAt  DateTime  @updatedAt @db.Timestamptz
  deletedAt  DateTime? @db.Timestamptz

  business   Business  @relation(fields: [businessId], references: [id])
  staff      Staff     @relation(fields: [staffId], references: [id])

  @@index([businessId])
  @@index([staffId])
  @@index([staffId, startTime, endTime])
  @@map("leaves")
}

model Review {
  id         String    @id @default(uuid()) @db.Uuid
  businessId String    @db.Uuid
  customerId String    @db.Uuid
  rating     Int
  comment    String?   @db.Text
  isApproved Boolean   @default(false)
  source     String    @default("internal") // "internal" or "google"
  version    Int       @default(1)
  createdBy  String?   @db.Uuid
  updatedBy  String?   @db.Uuid
  createdAt  DateTime  @default(now()) @db.Timestamptz
  updatedAt  DateTime  @updatedAt @db.Timestamptz
  deletedAt  DateTime? @db.Timestamptz

  business   Business  @relation(fields: [businessId], references: [id])
  customer   Customer  @relation(fields: [customerId], references: [id])

  @@index([businessId])
  @@index([customerId])
  @@map("reviews")
}

model Campaign {
  id                 String          @id @default(uuid()) @db.Uuid
  businessId         String          @db.Uuid
  name               String
  channel            CampaignChannel // WHATSAPP, SMS
  messageTemplate    String          @db.Text
  scheduledAt        DateTime?       @db.Timestamptz
  status             CampaignStatus  @default(DRAFT)
  sentCount          Int             @default(0)
  deliveredCount     Int             @default(0)
  clickCount         Int             @default(0)
  revenueAttributed  Decimal         @default(0.00) @db.Decimal(12, 2)
  version            Int             @default(1)
  createdBy          String?         @db.Uuid
  updatedBy          String?         @db.Uuid
  createdAt          DateTime        @default(now()) @db.Timestamptz
  updatedAt          DateTime        @updatedAt @db.Timestamptz
  deletedAt          DateTime?       @db.Timestamptz

  business           Business       @relation(fields: [businessId], references: [id])
  notifications      Notification[]

  @@index([businessId])
  @@map("campaigns")
}

model Membership {
  id             String    @id @default(uuid()) @db.Uuid
  businessId     String    @db.Uuid
  name           String
  price          Decimal   @db.Decimal(10, 2)
  durationMonths Int
  featuresJson   Json
  createdBy      String?   @db.Uuid
  updatedBy      String?   @db.Uuid
  createdAt      DateTime  @default(now()) @db.Timestamptz
  updatedAt      DateTime  @updatedAt @db.Timestamptz
  deletedAt      DateTime? @db.Timestamptz

  business       Business  @relation(fields: [businessId], references: [id])

  @@index([businessId])
  @@map("memberships")
}

model Package {
  id           String    @id @default(uuid()) @db.Uuid
  businessId   String    @db.Uuid
  name         String
  price        Decimal   @db.Decimal(10, 2)
  servicesJson Json
  createdBy    String?   @db.Uuid
  updatedBy    String?   @db.Uuid
  createdAt    DateTime  @default(now()) @db.Timestamptz
  updatedAt    DateTime  @updatedAt @db.Timestamptz
  deletedAt    DateTime? @db.Timestamptz

  business     Business  @relation(fields: [businessId], references: [id])

  @@index([businessId])
  @@map("packages")
}

model Inventory {
  id           String    @id @default(uuid()) @db.Uuid
  businessId   String    @db.Uuid
  name         String
  sku          String?
  stockLevel   Int       @default(0)
  reorderPoint Int       @default(5)
  price        Decimal   @db.Decimal(10, 2)
  createdBy    String?   @db.Uuid
  updatedBy    String?   @db.Uuid
  createdAt    DateTime  @default(now()) @db.Timestamptz
  updatedAt    DateTime  @updatedAt @db.Timestamptz
  deletedAt    DateTime? @db.Timestamptz

  business     Business  @relation(fields: [businessId], references: [id])

  @@unique([businessId, sku])
  @@map("inventory")
}

// --- DPDP Compliance ---

model Consent {
  id          String        @id @default(uuid()) @db.Uuid
  businessId  String        @db.Uuid
  customerId  String        @db.Uuid
  consentType ConsentType   // MARKETING_WHATSAPP, MARKETING_SMS, DATA_PROCESSING
  granted     Boolean
  source      ConsentSource // BOOKING_FORM, MANUAL, IMPORT
  version     Int           @default(1)
  grantedAt   DateTime      @default(now()) @db.Timestamptz
  revokedAt   DateTime?     @db.Timestamptz
  createdAt   DateTime      @default(now()) @db.Timestamptz

  business    Business @relation(fields: [businessId], references: [id])
  customer    Customer @relation(fields: [customerId], references: [id])

  @@index([businessId])
  @@index([businessId, customerId])
  @@map("consents")
}

model DataDeletionRequest {
  id          String                @id @default(uuid()) @db.Uuid
  businessId  String                @db.Uuid
  customerId  String                @db.Uuid
  status      DeletionRequestStatus @default(PENDING)
  scheduledAt DateTime              @db.Timestamptz // 30 days from request
  processedAt DateTime?             @db.Timestamptz
  createdAt   DateTime              @default(now()) @db.Timestamptz
  updatedAt   DateTime              @updatedAt @db.Timestamptz

  business    Business  @relation(fields: [businessId], references: [id])
  customer    Customer  @relation(fields: [customerId], references: [id])

  @@index([businessId])
  @@index([customerId])
  @@index([status])
  @@map("data_deletion_requests")
}

// --- Media Assets ---

model MediaAsset {
  id         String    @id @default(uuid()) @db.Uuid
  businessId String    @db.Uuid
  websiteId  String?   @db.Uuid
  fileName   String
  fileUrl    String
  fileType   String    // "image/jpeg", "image/png", "image/webp"
  sizeBytes  Int
  altText    String?
  createdBy  String?   @db.Uuid
  updatedBy  String?   @db.Uuid
  createdAt  DateTime  @default(now()) @db.Timestamptz
  updatedAt  DateTime  @updatedAt @db.Timestamptz
  deletedAt  DateTime? @db.Timestamptz

  business   Business @relation(fields: [businessId], references: [id])
  website    Website? @relation(fields: [websiteId], references: [id])

  @@index([businessId])
  @@map("media_assets")
}

model Incident {
  id               String           @id @default(uuid()) @db.Uuid
  severity         IncidentSeverity // P1, P2, P3, P4
  status           IncidentStatus   @default(OPEN)
  title            String
  description      String?          @db.Text
  startedAt        DateTime         @db.Timestamptz
  resolvedAt       DateTime?        @db.Timestamptz
  responseTimeMs   Int?
  resolutionTimeMs Int?
  cSatScore        Int?
  isRepeat         Boolean          @default(false)
  createdAt        DateTime         @default(now()) @db.Timestamptz
  updatedAt        DateTime         @updatedAt @db.Timestamptz

  @@map("incidents")
}

model SystemStatus {
  id        String           @id @default(uuid()) @db.Uuid
  component String           @unique // e.g. "api", "payments", "booking_engine", "notifications", "website_publishing", "infrastructure"
  status    SystemStatusType @default(OPERATIONAL)
  updatedAt DateTime         @updatedAt @db.Timestamptz
  updatedBy String           @db.Uuid

  @@map("system_statuses")
}
